# ===== APP =====
APP_NAME=JustHere
APP_ENV=production
APP_VERSION=1.0.0

# ===== API =====
API_BASE_URL=https://api.justhere.app
API_TIMEOUT=15000

# ===== AUTH =====
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
FACEBOOK_APP_ID=123456789012345
ZALO_APP_ID=987654321
ZALO_APP_SECRET=xxxxxxxxxxxxxxxx

# ===== APPLE SIGN IN =====
APPLE_TEAM_ID=5L4JL2V6VP
APPLE_KEY_ID=ABCD1234EF
APPLE_BUNDLE_ID=com.antstudio.justhere.app

# ===== ANDROID =====
ANDROID_PACKAGE_NAME=com.antstudio.justhere.app
ANDROID_HASH_KEY=Qk3x9kxxxxxxx=

# ===== LOCATION =====
LOCATION_ENABLED=true
LOCATION_MODE=coarse

# ===== ADS =====
ADS_PROVIDER=admob
ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxx~yyyyyyyy
ADMOB_IOS_APP_ID=ca-app-pub-xxxxxxxx~zzzzzzzz

# ===== FEATURE FLAGS =====
ENABLE_CHECK_IN=true
ENABLE_MEME_SUGGESTION=true
ENABLE_NOTIFICATIONS=true
